- name: play Level variables
  hosts: local
  connection: local
  vars:
    COURSE: Ansible
    DURATION: 10HRS
    Trainer: Kiran

  tasks:
  - name: print the course info
    vars:
      COURSE: DevOps
    ansible.builtin.debug:
      msg: "Course Name is: {{ COURSE }}, Duration {{ DURATION }}, Trainer {{ Trainer }}"